# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agenttip

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Email Service (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=summaries@agenttip.xyz

# Blockchain
ETH_MAINNET_RPC=https://eth.llamarpc.com
ESCROW_ADDRESS=0x...your_escrow_contract_address

# x402 Payment Protocol
X402_PAYMENT_AMOUNT=0.001
X402_ALLOW_FAKE_PAYMENTS=false

# Security
EXECUTOR_AGENT_KEY=your_secret_executor_key

# Server
PORT=3001
NODE_ENV=production
