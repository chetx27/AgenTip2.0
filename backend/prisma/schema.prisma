generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentType {
  human
  agent
}

enum TransactionStatus {
  pending
  confirmed
  failed
}

model Creator {
  id                   String    @id @default(cuid())
  wallet               String    @unique
  name                 String?
  fileversDocId        String?   @map("fileverse_doc_id")
  fileversDocHash      String?   @map("fileverse_doc_hash")
  email                String?
  summaryTime          String    @default("20:00") @map("summary_time")
  notificationsEnabled Boolean   @default(false) @map("notifications_enabled")
  createdAt            DateTime  @default(now()) @map("created_at")
  
  // ENS DeFi Will fields
  ensName          String?   @unique
  lastClaimedAt    DateTime?
  willStatus       String    @default("inactive")
  willExecutedAt   DateTime?
  totalEarnings    Float     @default(0)

  @@map("creators")
}

model WillExecution {
  id             String   @id @default(cuid())
  creatorWallet  String
  ensName        String
  totalAmount    Float
  action         String
  recipients     Json
  message        String
  txHashes       Json
  status         String   @default("executed")
  executedAt     DateTime @default(now())
}

model Transaction {
  id            String            @id @default(cuid())
  creatorWallet String            @map("creator_wallet")
  amount        Float
  currency      String            @default("USDC")
  type          String
  txHash        String            @unique @map("tx_hash")
  status        String            @default("pending")
  senderWallet  String?           @map("sender_wallet")
  agentContext  String?           @map("agent_context")
  agentQuery    String?           @map("agent_query")
  writtenToDoc  Boolean           @default(false) @map("written_to_doc")
  createdAt     DateTime          @default(now()) @map("created_at")

  @@index([creatorWallet])
  @@index([createdAt])
  @@map("transactions")
}

model Analytics {
  id            String @id @default(cuid())
  wallet        String @unique
  pageViews     Int    @default(0) @map("page_views")
  agentRequests Int    @default(0) @map("agent_requests")
  humanTips     Int    @default(0) @map("human_tips")
  totalEarnings Float  @default(0) @map("total_earnings")

  @@map("analytics")
}
